---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Barrierefreie Badberatung Osnabrück | Sicherheit & Komfort im eigenen Bad";
const pageDescription = "Professionelle Beratung für barrierefreie Badsanierung in Osnabrück. Bodengleiche Duschen, Haltegriffe, rutschfeste Böden – mit bis zu 4.180 € Pflegekassenzuschuss. Kostenlose Erstberatung!";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
  
  <main id="main-content">
    
    <!-- ==========================================
         HERO SECTION
         ========================================== -->
    <section 
      class="relative bg-gradient-to-br from-primary via-primary to-primary-dark text-white py-16 lg:py-24 overflow-hidden"
      aria-labelledby="hero-title"
    >
      <!-- Hintergrund Pattern -->
      <div class="absolute inset-0 opacity-10" aria-hidden="true">
        <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
          <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="0.5" fill="white"/>
          </pattern>
          <rect width="100" height="100" fill="url(#grid)"/>
        </svg>
      </div>
      
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          
          <!-- Text Content -->
          <div class="text-center lg:text-left">
            <!-- Badge: Pflegekassenzuschuss -->
            <div class="inline-flex items-center gap-2 bg-secondary/20 border border-secondary/30 rounded-full px-5 py-2.5 mb-6">
              <svg class="w-5 h-5 text-secondary-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="font-semibold text-secondary-light">
                Bis zu 4.180 € Pflegekassenzuschuss möglich!
              </span>
            </div>
            
            <h1 
              id="hero-title" 
              class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6"
            >
              Sicherheit & Komfort <span class="text-secondary">im eigenen Bad</span>
            </h1>
            
            <p class="text-xl lg:text-2xl text-gray-300 mb-10 leading-relaxed max-w-2xl mx-auto lg:mx-0">
              Barrierefreie Badmodernisierung für ein selbstbestimmtes Leben. 
              Wir machen Ihr Bad sicher – damit Sie lange selbstständig zu Hause leben können.
            </p>
            
            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
              <a 
                href="tel:+4954180067046" 
                class="inline-flex items-center justify-center gap-3 bg-secondary hover:bg-secondary-dark text-white font-bold text-xl px-8 py-5 rounded-xl transition-all duration-200 shadow-xl hover:shadow-2xl min-h-touch min-w-touch"
                aria-label="Jetzt kostenlos anrufen"
              >
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                Jetzt anrufen
              </a>
              
              <a 
                href="#kontakt" 
                class="inline-flex items-center justify-center gap-3 bg-white hover:bg-gray-100 text-primary font-bold text-xl px-8 py-5 rounded-xl transition-all duration-200 shadow-xl hover:shadow-2xl min-h-touch min-w-touch"
                aria-label="Nachricht über Kontaktformular schreiben"
              >
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                Nachricht schreiben
              </a>
            </div>
            
            <!-- Trust Indicators -->
            <div class="mt-10 flex flex-wrap items-center justify-center lg:justify-start gap-6 text-gray-400">
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="font-medium">Kostenlose Beratung</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="font-medium">Persönlich vor Ort</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="font-medium">Zuschuss-Abwicklung</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="font-medium">3D Planung</span>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span class="font-medium">KW Fördermöglichkeit</span>
              </div>
            </div>
          </div>
          
          <!-- Hero Image -->
          <div class="relative hidden lg:block">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
              <img
                src="/images/hero.png"
                alt="Modernes, barrierefreies Badezimmer mit bodengleicher Dusche und Haltegriffen"
                class="w-full h-auto object-cover"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                width="600"
                height="450"
              />
              <!-- Overlay Gradient -->
              <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent" aria-hidden="true"></div>
            </div>
            
            <!-- Floating Badge -->
            <div class="absolute -bottom-4 -left-4 bg-white text-primary p-4 rounded-xl shadow-xl">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-secondary/20 rounded-full flex items-center justify-center">
                  <svg class="w-7 h-7 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600">Zufriedene Kunden</p>
                  <p class="text-2xl font-bold">100+</p>
                </div>
              </div>
            </div>
          </div>
          
        </div>
      </div>
    </section>
    
    <!-- ==========================================
         PROBLEM / LÖSUNG (VORTEILE)
         ========================================== -->
    <section 
      class="py-16 lg:py-24 bg-gray-50"
      aria-labelledby="vorteile-title"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Section Header -->
        <div class="text-center max-w-3xl mx-auto mb-16">
          <span class="inline-block text-secondary font-semibold text-lg mb-3">Unsere Lösungen</span>
          <h2 id="vorteile-title" class="text-4xl lg:text-5xl font-bold text-primary mb-6">
            Ihr Bad – sicher und barrierefrei
          </h2>
          <p class="text-xl text-gray-600 leading-relaxed">
            Stolpern in der Dusche, Angst beim Ein- und Aussteigen – das muss nicht sein. 
            Wir zeigen Ihnen, wie Ihr Bad wieder ein Ort der Entspannung wird.
          </p>
        </div>
        
        <!-- 3-Spalten Grid -->
        <div class="grid md:grid-cols-3 gap-8 lg:gap-10">
          
          <!-- Vorteil 1: Bodengleiche Dusche -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow flex flex-col h-full">
            <img 
              src="/images/Bodengleich.jpg" 
              alt="Bodengleiche Dusche statt Badewanne"
              class="w-full h-48 object-cover rounded-2xl mb-6"
              loading="lazy"
            />
            <h3 class="text-2xl font-bold text-primary mb-4">Bodengleiche Dusche statt Badewanne</h3>
            <p class="text-lg text-gray-600 leading-relaxed flex-grow">
              Keine hohen Einstiege mehr. Eine ebenerdige Dusche ermöglicht einen sicheren,
              stolperfreien Zugang – perfekt für Rollator und Rollstuhl. Wir machen aus Ihrer
              Badewanne eine bodengleiche Dusche.
            </p>
            <div class="mt-6 pt-6 border-t border-gray-100">
              <div class="flex items-center gap-2 text-secondary font-semibold">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>Einfacher Einstieg</span>
              </div>
            </div>
          </div>
          
          <!-- Vorteil 2: Rutschfeste Materialien -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow flex flex-col h-full">
            <img 
              src="/images/rutschfest.jpg" 
              alt="Rutschfeste Materialien"
              class="w-full h-48 object-cover rounded-2xl mb-6"
              loading="lazy"
            />
            <h3 class="text-2xl font-bold text-primary mb-4">Rutschfeste Materialien</h3>
            <p class="text-lg text-gray-600 leading-relaxed flex-grow">
              Spezielle Fliesen und Bodenbeläge mit Rutschhemmung R10/R11 sorgen für sicheren 
              Halt – auch bei Seifenwasser. Moderne Designs, die Sicherheit mit Ästhetik verbinden.
            </p>
            <div class="mt-6 pt-6 border-t border-gray-100">
              <div class="flex items-center gap-2 text-secondary font-semibold">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>Sicherer Halt garantiert</span>
              </div>
            </div>
          </div>
          
          <!-- Vorteil 3: Haltegriffe -->
          <div class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow flex flex-col h-full">
            <img 
              src="/images/Haltegriffe.jpg" 
              alt="Haltegriffe und Sicherheit"
              class="w-full h-48 object-cover rounded-2xl mb-6"
              loading="lazy"
            />
            <h3 class="text-2xl font-bold text-primary mb-4">Haltegriffe & Sicherheit</h3>
            <p class="text-lg text-gray-600 leading-relaxed flex-grow">
              Strategisch platzierte Haltegriffe gehaltenen Halt beim Duschen und Toilettengang. 
              Klappbar oder fest montiert – wir finden die beste Lösung für Ihren Alltag.
            </p>
            <div class="mt-6 pt-6 border-t border-gray-100">
              <div class="flex items-center gap-2 text-secondary font-semibold">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>Mehr Selbstständigkeit</span>
              </div>
            </div>
          </div>
          
        </div>
        
        <!-- Zusätzliche Features -->
        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="flex items-center gap-4 bg-white p-5 rounded-xl shadow">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-primary">Höhenverstellbare Waschtische</h4>
              <p class="text-gray-600 text-base">Bequem im Sitzen oder Stehen</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4 bg-white p-5 rounded-xl shadow">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-primary">Duschabtrennung faltbar</h4>
              <p class="text-gray-600 text-base">Mehr Platz beim Duschen durch faltbare Duschabtrennung</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4 bg-white p-5 rounded-xl shadow">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-bold text-primary">Mehr Komfort und Sicherheit bei der Toilettennutzung</h4>
              <p class="text-gray-600 text-base">Versetzen und erhöhen der Toilette für ergonomisches Sitzen</p>
            </div>
          </div>
        </div>
        
      </div>
    </section>
    
    <!-- ==========================================
         ZUSCHUSS-ERKLÄRUNG (WICHTIG!)
         ========================================== -->
    <section 
      class="py-16 lg:py-24 bg-white"
      aria-labelledby="zuschuss-title"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          
          <!-- Text Content -->
          <div>
            <div class="inline-flex items-center gap-2 bg-green-100 text-green-800 rounded-full px-5 py-2 mb-6">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"/>
                <path fill-rule="evenodd" d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z" clip-rule="evenodd"/>
              </svg>
              <span class="font-semibold">Staatliche Förderung nutzen</span>
            </div>
            
            <h2 id="zuschuss-title" class="text-4xl lg:text-5xl font-bold text-primary mb-6">
              Bis zu 4.180 € Zuschuss von der Pflegekasse
            </h2>
            
            <p class="text-xl text-gray-600 leading-relaxed mb-8">
              Wussten Sie, dass die Pflegekasse bei einer wohnumfeldverbessernden Maßnahme
              <strong class="text-primary">bis zu 4.180 € pro Person</strong> bezuschusst?
              Das ist kein Darlehen – Sie müssen nichts zurückzahlen!
            </p>
            
            <!-- Schritte -->
            <div class="space-y-6">
              
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-12 h-12 bg-secondary text-white rounded-full flex items-center justify-center font-bold text-xl">
                  1
                </div>
                <div>
                  <h3 class="text-xl font-bold text-primary mb-2">Pflegegrad prüfen lassen</h3>
                  <p class="text-lg text-gray-600">
                    Sie oder Ihr Angehöriger benötigen mindestens Pflegegrad 1.
                    Falls noch nicht vorhanden, helfe ich bei der Beantragung.
                  </p>
                </div>
              </div>
              
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-12 h-12 bg-secondary text-white rounded-full flex items-center justify-center font-bold text-xl">
                  2
                </div>
                <div>
                  <h3 class="text-xl font-bold text-primary mb-2">Kostenlose Beratung</h3>
                  <p class="text-lg text-gray-600">
                    Ich besuche Sie vor Ort, begutachte Ihr Bad und erstelle ein
                    unverbindliches Konzept.
                  </p>
                </div>
              </div>
              
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-12 h-12 bg-secondary text-white rounded-full flex items-center justify-center font-bold text-xl">
                  3
                </div>
                <div>
                  <h3 class="text-xl font-bold text-primary mb-2">Antrag einreichen</h3>
                  <p class="text-lg text-gray-600">
                    Ich helfe Ihnen bei der korrekten Ausfüllung aller Formulare 
                    und reiche den Antrag bei Ihrer Pflegekasse ein.
                  </p>
                </div>
              </div>
              
              <div class="flex gap-5">
                <div class="flex-shrink-0 w-12 h-12 bg-secondary text-white rounded-full flex items-center justify-center font-bold text-xl">
                  4
                </div>
                <div>
                  <h3 class="text-xl font-bold text-primary mb-2">Zuschuss erhalten & loslegen</h3>
                  <p class="text-lg text-gray-600">
                    Nach Bewilligung durch die Pflegekasse wird der Zuschuss direkt 
                    an Sie ausgezahlt.
                  </p>
                </div>
              </div>
              
            </div>
            
            <!-- CTA -->
            <div class="mt-10">
              <a 
                href="tel:+4954180067046" 
                class="inline-flex items-center gap-3 bg-secondary hover:bg-secondary-dark text-white font-bold text-xl px-8 py-5 rounded-xl transition-all shadow-lg hover:shadow-xl min-h-touch"
                aria-label="Kostenlose Beratung zum Pflegekassenzuschuss anrufen"
              >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                Gratis beraten lassen
              </a>
            </div>
            
          </div>
          
          <!-- Image -->
          <div class="relative">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
              <img 
                src="/images/beratung.png" 
                alt="Beratungsgespräch zur Pflegekassenzuschuss-Beantragung"
                class="w-full h-auto object-cover"
                loading="lazy"
                width="600"
                height="500"
              />
            </div>
            
            <!-- Info Box -->
            <div class="mt-6 bg-primary text-white p-6 rounded-xl shadow-xl">
              <div class="flex items-start gap-4">
                <svg class="w-8 h-8 text-secondary flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <h4 class="font-bold text-lg mb-2">Wichtig zu wissen:</h4>
                  <ul class="space-y-2 text-gray-200">
                    <li class="flex items-start gap-2">
                      <span class="text-secondary">✓</span>
                      <span>Der Zuschuss gilt pro pflegebedürftiger Person im Haushalt</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-secondary">✓</span>
                      <span>Auch für Ehepartner/Angehörige mit Pflegegrad</span>
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="text-secondary">✓</span>
                      <span>KW Zuschüsse (455-B) können beantragt werden</span>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
          
        </div>
        
      </div>
    </section>
    
    <!-- ==========================================
         ÜBER DEN INHABER
         ========================================== -->
    <section 
      class="py-16 lg:py-24 bg-gray-50"
      aria-labelledby="ueber-title"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          
          <!-- Portrait Image -->
          <div class="order-2 lg:order-1">
            <div class="relative max-w-md mx-auto lg:mx-0">

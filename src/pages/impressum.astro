---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Content, frontmatter } from '../content/pages/impressum.md';

const { title, description, heading, subheading } = frontmatter;
---

<Layout title={title} description={description}>
  <Header />
  
  <main id="main-content">
    
    <!-- Page Header -->
    <section class="bg-primary text-white py-12 lg:py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">{heading}</h1>
        <p class="text-xl text-gray-300">{subheading}</p>
      </div>
    </section>
    
    <!-- Content -->
    <section class="py-12 lg:py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="prose prose-lg max-w-none prose-custom text-gray-600">
          <Content />
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>

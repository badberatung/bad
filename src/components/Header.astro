---
// Header Komponente - Sticky mit großem Telefon-CTA
---

<header class="sticky top-0 z-50 bg-white shadow-md" role="banner">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 lg:h-24">
      
      <!-- Logo / Brand -->
      <a 
        href="/" 
        class="flex items-center transition-opacity hover:opacity-80"
        aria-label="Barrierefreie Badberatung - Zur Startseite"
      >
        <!-- Logo Bild -->
        <img 
          src="/images/logo.png" 
          alt="Barrierefreie Badberatung Logo"
          class="h-14 lg:h-16 w-auto object-contain"
          width="200"
          height="64"
        />
      </a>
      
      <!-- Haupt-CTA: Telefonnummer -->
      <div class="flex items-center">
        <a 
          href="tel:+4954180067046" 
          class="group flex items-center gap-3 bg-secondary hover:bg-secondary-dark text-white px-5 py-3 lg:px-6 lg:py-4 rounded-xl transition-all duration-200 shadow-lg hover:shadow-xl min-h-touch"
          aria-label="Jetzt anrufen: 0541 80067046"
        >
          <!-- Telefon Icon -->
          <svg 
            class="w-7 h-7 lg:w-8 lg:h-8 flex-shrink-0" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            />
          </svg>
          
          <div class="text-left">
            <span class="hidden lg:block text-xs lg:text-sm opacity-90 font-medium">
              Kostenlos beraten lassen
            </span>
            <span class="block text-xl lg:text-2xl font-bold tracking-wide">
              0541 80067046
            </span>
          </div>
        </a>
      </div>
      
    </div>
  </div>
</header>
